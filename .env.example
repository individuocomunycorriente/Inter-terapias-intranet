# ==============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN (BACKEND)
# ==============================================================================
NODE_ENV=development
PORT=4000

# ==============================================================================
# CONFIGURACIÓN DE POSTGRESQL (DOCKER CONTAINER)
# ==============================================================================
DB_USER=interterapia_admin
DB_PASSWORD=change_me
DB_NAME=interterapia_db
DB_PORT=5432

# Cuenta de administrador creada por el seed inicial de Prisma
ADMIN_EMAIL="admin@interterapia.cl"
ADMIN_PASSWORD="change_me"

# Secreto usado para firmar los JWT de sesión — usar un valor largo y aleatorio, nunca el de este ejemplo
JWT_SECRET=change_me

# URL del frontend permitida por CORS para el uso de cookies de sesión
FRONTEND_URL=http://localhost:5173

# Debe coincidir con DB_USER/DB_PASSWORD/DB_NAME de arriba
DATABASE_URL="postgresql://interterapia_admin:change_me@db:5432/interterapia_db?schema=public"
